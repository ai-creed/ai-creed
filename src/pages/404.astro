---
import Base from "~/layouts/Base.astro";
---
<Base title="404 — ai-creed" description="Route not found.">
	<section class="container center">
		<p class="line">
			<span class="prompt">$</span> route not found — <a href="/">↩ home</a>
		</p>
	</section>
</Base>

<style>
	.center {
		min-height: 40vh;
		display: flex;
		align-items: center;
	}
	.line { font-size: var(--fs-base); }
	.prompt { color: var(--accent); margin-right: var(--s-2); }
</style>
