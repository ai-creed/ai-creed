---
import Base from "~/layouts/Base.astro";
import PromptTitle from "~/components/PromptTitle.astro";
import ProjectCard from "~/components/ProjectCard.astro";
import { getCollection } from "astro:content";
import { SITE_CONTACT_EMAIL } from "~/consts";

const projects = (await getCollection("projects")).sort(
	(a, b) => a.data.order - b.data.order,
);
---
<Base title="ai-creed — local-first ai dev tooling">
	<section class="hero container">
		<PromptTitle text="local-first ai dev tooling" />
		<p class="blurb subtitle">
			five tools. one philosophy. built for agents that live on your machine.
		</p>
	</section>

	<section id="projects" class="container section">
		<h2 class="heading"># projects</h2>
		<div class="grid">
			{projects.map((p) => (
				<ProjectCard
					slug={p.id}
					name={p.data.name}
					tagline={p.data.tagline}
					status={p.data.status}
					wip={p.data.wip}
				/>
			))}
		</div>
	</section>

	<section id="about" class="container section">
		<h2 class="heading"># about</h2>
		<p>
			ai-creed is a small family of local-first AI developer tools. The agent is a
			tool, not the product. Everything here favors terseness, ownership of your
			own workstation, and code you can read end-to-end.
		</p>
	</section>

	<section id="collab" class="container section">
		<h2 class="heading"># collab</h2>
		<p>
			if any of these tools fit your flow or you want to help push one further —
			bug reports, pull requests, or "hey this should do X" emails all welcome.
			<a href={`mailto:${SITE_CONTACT_EMAIL}`}>say hi</a>.
		</p>
	</section>
</Base>

<style>
	.hero {
		padding-top: var(--s-4);
		padding-bottom: var(--s-8);
	}
	.blurb {
		margin-top: var(--s-3);
		max-width: 560px;
	}
	.heading {
		color: var(--fg-dim);
		font-weight: 500;
		margin-bottom: var(--s-4);
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--s-3);
	}
	@media (max-width: 640px) {
		.grid { grid-template-columns: 1fr; }
	}
</style>
