---
import { SITE_GITHUB_URL, SITE_CONTACT_EMAIL } from "~/consts";
---
<footer class="site-footer">
	<div class="container">
		<p class="subtitle">
			ai-creed · built by Vu Phan and his friends ·
			<a href={SITE_GITHUB_URL}>github</a> ·
			<a href={`mailto:${SITE_CONTACT_EMAIL}`}>{SITE_CONTACT_EMAIL}</a>
			· 2026
		</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid var(--border);
		padding: var(--s-4) 0;
		font-size: var(--fs-xs);
	}
</style>
