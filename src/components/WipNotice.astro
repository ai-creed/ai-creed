---
import { SITE_CONTACT_EMAIL } from "~/consts";
---
<aside class="wip" role="note" aria-label="work in progress">
	<p class="line">
		<span class="tag">[wip]</span>
		under construction — actively evolving, interfaces will change.
	</p>
	<p class="line invite">
		interested in contributing or testing an early build?
		<a href={`mailto:${SITE_CONTACT_EMAIL}`}>{SITE_CONTACT_EMAIL}</a>
	</p>
</aside>

<style>
	.wip {
		margin: var(--s-6) 0;
		padding: var(--s-3) var(--s-4);
		border: 1px dashed var(--warn);
		border-radius: var(--radius);
		background: var(--bg-raised);
		font-size: var(--fs-sm);
	}
	.line { margin: 0; }
	.line + .line { margin-top: var(--s-2); }
	.tag {
		color: var(--warn);
		font-weight: 600;
		margin-right: var(--s-2);
	}
	.invite { color: var(--fg-dim); }
</style>
