---
import StatusChip from "~/components/StatusChip.astro";

interface Props {
	slug: string;
	name: string;
	tagline: string;
	status: "public" | "private" | "stable";
	wip?: boolean;
}
const { slug, name, tagline, status, wip } = Astro.props;
---
<a class="card" href={`/projects/${slug}`}>
	<div class="top">
		<span class="name">
			{name}
			{wip && <span class="wip-tag" title="work in progress">[wip]</span>}
		</span>
		<StatusChip status={status} />
	</div>
	<p class="tagline">{tagline}</p>
	<span class="arrow" aria-hidden="true">→</span>
</a>

<style>
	.card {
		display: block;
		position: relative;
		padding: var(--s-4);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		background: var(--bg-raised);
		color: var(--fg);
		text-decoration: none;
		transition: border-color var(--dur) ease;
	}
	.card:hover { border-color: var(--accent); }
	.card:hover .arrow { color: var(--accent); }
	.top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: var(--s-3);
		margin-bottom: var(--s-2);
	}
	.name { font-size: var(--fs-base); font-weight: 600; }
	.wip-tag {
		margin-left: var(--s-2);
		color: var(--warn);
		font-weight: 500;
		font-size: var(--fs-xs);
	}
	.tagline { color: var(--fg-dim); font-size: var(--fs-sm); }
	.arrow {
		position: absolute;
		right: var(--s-4);
		bottom: var(--s-3);
		color: var(--fg-muted);
		transition: color var(--dur) ease;
	}
</style>
